# Google Analytics 4 measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-0HRPEYEZXY

# Google Ads account/tag ID, for example AW-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_ID=

# Google Ads conversion label for qualified leads
NEXT_PUBLIC_GOOGLE_ADS_LEAD_LABEL=

# Google Ads conversion label for WhatsApp clicks (create the "WhatsApp click"
# conversion action in Google Ads first; leave empty until it exists)
NEXT_PUBLIC_GOOGLE_ADS_WHATSAPP_LABEL=

# Optional conversion value used for lead events
NEXT_PUBLIC_GOOGLE_ADS_LEAD_VALUE=1
NEXT_PUBLIC_GOOGLE_ADS_LEAD_CURRENCY=MAD

# Optional booking embed slug, for example wereact/30min
NEXT_PUBLIC_CALCOM_LINK=
# Resend server-side contact delivery
RESEND_API_KEY=
RESEND_FROM_EMAIL=WeReact <hello@wereact.agency>
CONTACT_RECIPIENT_EMAIL=anasbenbow123@gmail.com
RESEND_NEWSLETTER_SEGMENT_ID=
# Signing secret from Resend > Webhooks. Keep server-side only.
RESEND_WEBHOOK_SECRET=

# Private Supabase lead inbox (server-side only)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Private recovery endpoint used by Cloudflare Cron/Workflows.
AUTOMATION_INTERNAL_SECRET=
AUTOMATION_BATCH_SIZE=10

# Server-only Gemini sales assistant
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# --- Google Ads API (read-only diagnostics) -------------------------------
# Setup guide: scripts/google-ads/README.md. Put real values in .env.local.
# Developer token from Google Ads Manager > Tools > API Center (needs Basic Access).
GOOGLE_ADS_DEVELOPER_TOKEN=
# OAuth client (Google Cloud > Credentials > "Desktop app").
GOOGLE_ADS_OAUTH_CLIENT_ID=
GOOGLE_ADS_OAUTH_CLIENT_SECRET=
# Minted by `npm run ads:token`.
GOOGLE_ADS_REFRESH_TOKEN=
# The ad account to query (digits only, no dashes). Find via `npm run ads:list`.
GOOGLE_ADS_CUSTOMER_ID=
# Only if accessing through a Manager/MCC account (digits only).
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
# Check https://developers.google.com/google-ads/api/docs/release-notes and set the current version.
GOOGLE_ADS_API_VERSION=v21
# Optional reporting window covering your campaign (defaults to LAST_30_DAYS).
GOOGLE_ADS_START_DATE=
GOOGLE_ADS_END_DATE=
