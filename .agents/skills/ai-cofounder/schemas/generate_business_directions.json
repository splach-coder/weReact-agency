{
  "name": "generate_business_directions",
  "description": "Produce 3-5 distinct business directions synthesized from all prior founder data. Call after all inference steps are complete. Requires all collected and inferred data as explicit inputs.",
  "input_schema": {
    "type": "object",
    "properties": {
      "skills": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/SkillItem"
        },
        "description": "The founder's structured skill items."
      },
      "interests": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/InterestCluster"
        },
        "description": "The founder's interest clusters."
      },
      "experience": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/ExperienceSegment"
        },
        "description": "The founder's structured experience segments."
      },
      "constraints": {
        "type": "object",
        "properties": {
          "budget": {
            "type": "string",
            "enum": ["bootstrap", "small", "medium", "funded"],
            "description": "The founder's available budget tier."
          },
          "time_commitment": {
            "type": "string",
            "enum": ["side_project", "part_time", "full_time"],
            "description": "How much time the founder can dedicate."
          },
          "risk_tolerance": {
            "type": "string",
            "enum": ["low", "medium", "high"],
            "description": "How much risk the founder is willing to accept."
          }
        },
        "required": ["budget", "time_commitment", "risk_tolerance"],
        "additionalProperties": true,
        "description": "The founder's business constraints."
      },
      "segments": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/CustomerSegment"
        },
        "description": "Inferred customer segments."
      },
      "problems": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/ProblemStatement"
        },
        "description": "Inferred problem statements."
      },
      "value_proposition": {
        "type": "object",
        "properties": {
          "proposition": {
            "type": "string",
            "description": "The composed value proposition statement."
          },
          "for_segment": {
            "type": "string",
            "description": "The target customer segment."
          },
          "solves_problem": {
            "type": "string",
            "description": "The specific problem addressed."
          }
        },
        "required": ["proposition", "for_segment", "solves_problem"],
        "additionalProperties": true,
        "description": "The inferred value proposition."
      },
      "business_models": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/BusinessModel"
        },
        "description": "Inferred business models."
      }
    },
    "required": ["skills", "interests", "experience", "constraints", "segments", "problems", "value_proposition", "business_models"],
    "additionalProperties": false
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "directions": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/Direction"
        },
        "minItems": 3,
        "maxItems": 5,
        "description": "Distinct business directions synthesized from all founder data."
      }
    },
    "required": ["directions"],
    "additionalProperties": true
  },
  "$defs": {
    "SkillItem": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the skill."
        },
        "category": {
          "type": "string",
          "enum": ["technical", "business", "creative", "interpersonal"],
          "description": "Broad category the skill falls into."
        },
        "proficiency": {
          "type": "string",
          "enum": ["beginner", "intermediate", "advanced", "expert"],
          "description": "Self-assessed or inferred proficiency level."
        }
      },
      "required": ["name", "category", "proficiency"],
      "additionalProperties": false
    },
    "InterestCluster": {
      "type": "object",
      "properties": {
        "theme": {
          "type": "string",
          "description": "Central theme of the interest cluster."
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Keywords associated with this interest theme."
        },
        "intensity": {
          "type": "string",
          "enum": ["casual", "moderate", "passionate"],
          "description": "How strongly the founder feels about this interest."
        }
      },
      "required": ["theme", "keywords", "intensity"],
      "additionalProperties": false
    },
    "ExperienceSegment": {
      "type": "object",
      "properties": {
        "domain": {
          "type": "string",
          "description": "Industry or domain of experience."
        },
        "role": {
          "type": "string",
          "description": "Role or function held in this domain."
        },
        "years": {
          "type": "number",
          "description": "Approximate years of experience in this domain."
        },
        "insider_knowledge": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Key insights or insider knowledge gained in this domain."
        }
      },
      "required": ["domain", "role", "insider_knowledge"],
      "additionalProperties": false
    },
    "CustomerSegment": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the customer segment."
        },
        "description": {
          "type": "string",
          "description": "Description of who this segment is."
        },
        "pain_points": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Key pain points experienced by this segment."
        },
        "willingness_to_pay": {
          "type": "string",
          "description": "Estimated willingness to pay for a solution."
        },
        "accessibility": {
          "type": "string",
          "description": "How easily the founder can reach this segment."
        }
      },
      "required": ["name", "description", "pain_points"],
      "additionalProperties": false
    },
    "ProblemStatement": {
      "type": "object",
      "properties": {
        "statement": {
          "type": "string",
          "description": "A clear articulation of the problem."
        },
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"],
          "description": "How severe this problem is for the affected segment."
        },
        "frequency": {
          "type": "string",
          "description": "How often the problem occurs."
        },
        "existing_solutions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Known existing solutions or workarounds."
        }
      },
      "required": ["statement", "severity"],
      "additionalProperties": false
    },
    "BusinessModel": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["saas", "marketplace", "service", "product", "content", "consulting", "freemium", "licensing"],
          "description": "The business model archetype."
        },
        "revenue_mechanism": {
          "type": "string",
          "description": "How this model generates revenue."
        },
        "fit_score": {
          "type": "number",
          "description": "How well this model fits the founder's profile (0-1)."
        },
        "rationale": {
          "type": "string",
          "description": "Why this model is recommended for this founder."
        }
      },
      "required": ["type", "revenue_mechanism", "fit_score", "rationale"],
      "additionalProperties": false
    },
    "Direction": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Short name for this business direction."
        },
        "one_liner": {
          "type": "string",
          "description": "One-sentence summary of the direction."
        },
        "target_segment": {
          "type": "string",
          "description": "The primary customer segment targeted."
        },
        "business_model": {
          "type": "string",
          "description": "The recommended business model type."
        },
        "key_advantage": {
          "type": "string",
          "description": "The founder's key advantage in pursuing this direction."
        },
        "feasibility_score": {
          "type": "number",
          "description": "How feasible this direction is (0-1)."
        },
        "market_score": {
          "type": "number",
          "description": "Estimated market opportunity score (0-1)."
        },
        "founder_fit_score": {
          "type": "number",
          "description": "How well this direction fits the founder (0-1)."
        }
      },
      "required": ["name", "one_liner", "target_segment", "business_model", "feasibility_score", "founder_fit_score"],
      "additionalProperties": false
    }
  }
}
