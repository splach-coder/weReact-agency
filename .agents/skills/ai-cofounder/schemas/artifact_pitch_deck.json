{
  "name": "artifact_pitch_deck",
  "description": "Generate a structured pitch deck with slides covering problem, solution, market, model, and ask. Call when the founder wants a pitch deck. Requires the refined concept.",
  "input_schema": {
    "type": "object",
    "properties": {
      "concept": {
        "$ref": "#/$defs/RefinedConcept",
        "description": "The refined concept to generate a pitch deck for."
      }
    },
    "required": ["concept"],
    "additionalProperties": false
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "slides": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string",
              "description": "Slide title."
            },
            "content": {
              "type": "string",
              "description": "Main slide content."
            },
            "talking_points": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Key talking points for this slide."
            },
            "visual_suggestion": {
              "type": "string",
              "description": "Suggested visual or graphic for this slide."
            }
          },
          "required": ["title", "content", "talking_points"],
          "additionalProperties": false
        },
        "description": "Ordered list of pitch deck slides."
      }
    },
    "required": ["slides"],
    "additionalProperties": true
  },
  "$defs": {
    "RefinedConcept": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the refined concept."
        },
        "refined_proposition": {
          "type": "string",
          "description": "The refined value proposition after evaluation."
        },
        "risks": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Identified risks for this direction."
        },
        "next_actions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Recommended next steps to pursue this direction."
        },
        "open_questions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Unresolved questions that need further exploration."
        }
      },
      "required": ["name", "refined_proposition", "risks", "next_actions"],
      "additionalProperties": false
    }
  }
}
