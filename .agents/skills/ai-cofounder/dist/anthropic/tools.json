[
  {
    "name": "collect_skills",
    "description": "Extract and structure the founder's professional skills from free-text input. Call this first in the Founder Discovery Flow to understand what the founder is good at. Expects the founder's natural-language response about their skills and talents.",
    "input_schema": {
      "type": "object",
      "properties": {
        "response": {
          "type": "string",
          "description": "The founder's natural-language response about their skills and talents."
        },
        "prior_skills": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Name of the skill."
              },
              "category": {
                "type": "string",
                "enum": ["technical", "business", "creative", "interpersonal"],
                "description": "Broad category the skill falls into."
              },
              "proficiency": {
                "type": "string",
                "enum": ["beginner", "intermediate", "advanced", "expert"],
                "description": "Self-assessed or inferred proficiency level."
              }
            },
            "required": ["name", "category", "proficiency"],
            "additionalProperties": false
          },
          "description": "Previously collected skills to merge with or refine."
        }
      },
      "required": ["response"],
      "additionalProperties": false
    }
  },
  {
    "name": "collect_interests",
    "description": "Identify and cluster the founder's personal and professional interests from free-text input. Call after collecting skills to understand what excites the founder. Expects the founder's response about their passions and interests.",
    "input_schema": {
      "type": "object",
      "properties": {
        "response": {
          "type": "string",
          "description": "The founder's natural-language response about their passions and interests."
        },
        "prior_interests": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "theme": {
                "type": "string",
                "description": "Central theme of the interest cluster."
              },
              "keywords": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Keywords associated with this interest theme."
              },
              "intensity": {
                "type": "string",
                "enum": ["casual", "moderate", "passionate"],
                "description": "How strongly the founder feels about this interest."
              }
            },
            "required": ["theme", "keywords", "intensity"],
            "additionalProperties": false
          },
          "description": "Previously collected interest clusters to merge with or refine."
        }
      },
      "required": ["response"],
      "additionalProperties": false
    }
  },
  {
    "name": "collect_experience",
    "description": "Parse the founder's professional experience into structured domain segments. Call after collecting interests to map the founder's background. Expects the founder's response about their work history and expertise areas.",
    "input_schema": {
      "type": "object",
      "properties": {
        "response": {
          "type": "string",
          "description": "The founder's natural-language response about their work history and expertise areas."
        },
        "prior_experience": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "domain": {
                "type": "string",
                "description": "Industry or domain of experience."
              },
              "role": {
                "type": "string",
                "description": "Role or function held in this domain."
              },
              "years": {
                "type": "number",
                "description": "Approximate years of experience in this domain."
              },
              "insider_knowledge": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Key insights or insider knowledge gained in this domain."
              }
            },
            "required": ["domain", "role", "insider_knowledge"],
            "additionalProperties": false
          },
          "description": "Previously collected experience segments to merge with or refine."
        }
      },
      "required": ["response"],
      "additionalProperties": false
    }
  },
  {
    "name": "collect_constraints",
    "description": "Extract the founder's business constraints including budget, time, risk tolerance, and hard limits. Call after collecting experience to understand the founder's boundaries. Expects the founder's response about their resources and limitations.",
